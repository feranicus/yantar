# jev.best — 1:1 по образцу работающего cybergod.ai (deploy/caddy/cybergod.caddy).
# apex + www в ОДНОМ блоке (один серт на оба имени). Общий edge-Caddy терминирует TLS и
# проксирует к нашему контейнеру. Никаких лишних директив (log-в-файл/заголовки) — они не нужны
# для выпуска серта и только добавляли переменных; их можно вернуть ПОСЛЕ того, как серт живой.
jev.best, www.jev.best {
	encode zstd gzip
	reverse_proxy jev-web:8080
}
