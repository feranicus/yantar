# jev.best backend secrets — положи РЕАЛЬНЫЙ файл на дроплет как /opt/jevbest/.env
# (в репозиторий НЕ коммитим; .gitignore и tar деплоя отбрасывают *.env).
# Ключи — те же, что в cybergod .env (DO Inference).
OPENAI_API_KEY=do_inference_key_from_cybergod_env
OPENAI_BASE_URL=https://inference.do-ai.run/v1
JEV_CHAT_MODELS=deepseek-3.2,llama-4-maverick
# опционально — трейсы OpenTelemetry (если поднимешь OTLP-коллектор/Tempo):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://videodead-tempo:4318
# OTEL_SERVICE_NAME=jev-api
