{
  "uid": "jevbest-web",
  "title": "jev.best — Web (visitors + security)",
  "tags": [
    "jev.best",
    "jevbest",
    "observability",
    "security"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "liveNow": true,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "ds",
        "label": "Loki",
        "query": "loki",
        "hide": 0,
        "refresh": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "jev.best — Visitors",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Visits (24h)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" [24h]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique humans (IPs)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (ip)(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"false\" [24h])))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bots (24h)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"true\" [24h]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "4xx / 5xx (24h)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | status=~\"4..|5..\" [24h]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
