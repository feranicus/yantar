          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          },
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top human IPs (24h)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, sum by (ip)(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"false\" [24h])))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          }
        }
      ],
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Bots / scanners seen (24h)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, sum by (bot_name)(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"true\" [24h])))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          }
        }
      ],
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Visitor log",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | line_format \"{{.method}} {{.path}} → {{.status}}  {{.ms}}ms  {{.ip}}  {{.country}}  {{.device}}  {{.bot_name}}\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          }
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "jev.best — Security",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
