      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Traffic / min — humans vs bots",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"false\" [1m]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          },
          "legendFormat": "humans"
        },
        {
          "refId": "B",
          "expr": "sum(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"true\" [1m]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          },
          "legendFormat": "bots"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 14,
            "showPoints": "never",
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Countries (humans, 24h)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (country)(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"false\" [24h]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "${ds}"
          },
          "legendFormat": "{{country}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        }
      }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Devices (humans, 24h)",
      "datasource": {
        "type": "loki",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (device)(count_over_time({container=~\".*assess-bot.*\"} | json | service=\"jev-web\" | evt=\"http\" | bot=\"false\" [24h]))",
